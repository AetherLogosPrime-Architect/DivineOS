{
  "enabled": false,
  "name": "Capture session end",
  "version": "1.0.0",
  "description": "Manual hook - user runs this when they want to close a session",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Session is ending. Do two things: (1) Provide a brief summary of what was accomplished this session - what changed, what was fixed, what's the current state. Keep it concise, just the facts. (2) Then emit a SESSION_END event to capture the end of this session in the DivineOS ledger. Run: divineos emit SESSION_END. This command will automatically query the ledger to get actual counts of USER_INPUT, TOOL_CALL, and TOOL_RESULT events for this session, calculate the session duration, and store everything with SHA256 hashing."
  }
}
